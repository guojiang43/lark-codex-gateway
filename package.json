{
  "name": "lark-codex-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "A privacy-conscious gateway between Feishu/Lark bots and local Codex sessions on macOS.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guojiang43/lark-codex-gateway.git"
  },
  "bugs": {
    "url": "https://github.com/guojiang43/lark-codex-gateway/issues"
  },
  "homepage": "https://github.com/guojiang43/lark-codex-gateway#readme",
  "keywords": [
    "codex",
    "feishu",
    "lark",
    "gateway",
    "macos"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.19"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/src/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "1.70.0",
    "ws": "8.21.0"
  },
  "overrides": {
    "axios": "1.18.1"
  },
  "devDependencies": {
    "@types/node": "22.19.3",
    "@types/ws": "8.18.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
